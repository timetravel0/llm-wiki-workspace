# llm-wiki-workspace - Environment Variables Template
# Copy this file to .env for standalone local runs.

# Integrated local platform
# Keep disabled for standalone use. Set to true when Wiki Service should read
# shared integration values from the root workspace .env.shared file.
WIKI_LOAD_SHARED_ENV=true
WIKI_SHARED_ENV_PATH=../.env.shared

# When WIKI_LOAD_SHARED_ENV=true, keep INTERNAL_API_TOKEN, WIKI_DOCS_DIR,
# WIKI_SERVICE_PORT, and WIKI_MAX_FILE_SIZE_BYTES in ../.env.shared to avoid drift.
# For standalone-only runs, you can define those values in a local .env file.

# Optional integrated publishing target used by scripts/publish_to_integrated_platform.py
WIKI_SERVICE_URL=http://127.0.0.1:8200
SIMPLE_RAG_URL=http://127.0.0.1:8000
